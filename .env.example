# Django
SECRET_KEY=your-long-random-secret-key
DEBUG=True

# --- Database (keep PCG and Samsonllc separate) ---
# Production (Render): each web service gets its OWN DATABASE_URL when you
# link a Postgres instance to THAT service only. Do not copy PCG's URL here.
# DATABASE_URL=postgres://samsonllc_user:pass@dpg-xxxx/samsonllc

# Local dev for Samsonllc only (when DATABASE_URL is unset):
# DB_NAME=Samsonllc
# DB_USER=postgres
# DB_PASSWORD=your-local-password
# DB_HOST=localhost
# DB_PORT=5432

FRONTEND_URL=http://localhost:5173
ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com

# --- Render: Samsonllc_backend service (separate from PCG_backend) ---
# 1. New Postgres named e.g. samsonllc-db (NOT the PCG database)
# 2. Link samsonllc-db to this web service only
# 3. Build command:  ./build.sh
# 4. Start command:  ./start.sh
# 5. Env: DEBUG=False, SECRET_KEY=<unique>, FRONTEND_URL=https://eliteforge.netlify.app
#    DATABASE_URL is auto-set by Render when DB is linked — do not paste PCG's URL

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# PayPal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
PAYPAL_WEBHOOK_ID=

# --- Email (required on Render for tracking emails to reach customers) ---
# Without these, Django uses the console backend — success in admin but no real email.
# SendGrid example:
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=SG.your-sendgrid-api-key
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=orders@yourdomain.com
#
# Gmail (use an App Password, not your normal password):
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=you@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=you@gmail.com

# --- AWS S3 (required on Render for product images) — see docs/AWS_S3_SETUP.md ---
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=your-bucket-name
# AWS_S3_REGION_NAME=us-east-2
# AWS_LOCATION=media
