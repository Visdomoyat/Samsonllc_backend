# Django
SECRET_KEY=your-long-random-secret-key
DEBUG=True

# Database — Render/production sets DATABASE_URL automatically
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# Local PostgreSQL (used when DATABASE_URL is unset)
# DB_NAME=Samsonllc
# DB_USER=postgres
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=5432

# Customer frontend URL (Stripe/PayPal redirects)
FRONTEND_URL=http://localhost:5173

# Comma-separated; Render adds RENDER_EXTERNAL_HOSTNAME automatically
ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com

# --- Render deploy (Dashboard or render.yaml) ---
# Build command:  ./build.sh   (or leave default: pip install -r requirements.txt + migrate in build.sh)
# Start command:  gunicorn Samsonllc.wsgi:application --bind 0.0.0.0:$PORT
# Regenerate requirements.txt after Pipfile changes: pipenv requirements > requirements.txt
# Env: DEBUG=False, SECRET_KEY, FRONTEND_URL=https://eliteforge.netlify.app, DATABASE_URL (auto)
# Stripe — https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Stripe CLI: stripe listen --forward-to localhost:8000/api/webhooks/stripe/
STRIPE_WEBHOOK_SECRET=whsec_...

# PayPal — https://developer.paypal.com/dashboard/applications/sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
PAYPAL_WEBHOOK_ID=
